# AI FXDealer — Environment variable template
# Copy to .env.local for local dev. Never commit .env.local.
# All secrets in production come from AWS Secrets Manager.

# ── Database ────────────────────────────────────────────────────────────────
FXDEALER_DB_URL=postgresql://fxdealer:fxdealer@localhost:5432/fxdealer

# ── Redis ───────────────────────────────────────────────────────────────────
FXDEALER_REDIS_URL=redis://localhost:6379/0

# ── Auth ────────────────────────────────────────────────────────────────────
FXDEALER_JWT_SECRET=
FXDEALER_JWT_EXPIRY_SECONDS=3600

# ── AWS ─────────────────────────────────────────────────────────────────────
FXDEALER_AWS_REGION=eu-west-1

# ── Observability ────────────────────────────────────────────────────────────
FXDEALER_SENTRY_DSN=
FXDEALER_LOG_LEVEL=INFO

# ── Deployment mode ──────────────────────────────────────────────────────────
# saas = multi-tenant on your AWS
# selfhosted = single-tenant on broker's server (future)
FXDEALER_DEPLOYMENT_MODE=saas

# ── Collector secrets (local dev only — use AWS SM key refs in production) ──
# Credentials below are stored in AWS Secrets Manager in production.
# Key name pattern: fxdealer/broker/{broker_id}/{system}

# MT5
FXDEALER_MT5_SERVER=
FXDEALER_MT5_LOGIN=
FXDEALER_MT5_PASSWORD=

# MT4 (DLL path is Windows-only)
FXDEALER_MT4_DLL_PATH=
FXDEALER_MT4_SERVER=
FXDEALER_MT4_LOGIN=
FXDEALER_MT4_PASSWORD=

# cTrader
FXDEALER_CTRADER_HOST=
FXDEALER_CTRADER_PORT=5392
FXDEALER_CTRADER_PLANT_ID=
FXDEALER_CTRADER_ENV_NAME=
FXDEALER_CTRADER_LOGIN=
FXDEALER_CTRADER_PASSWORD=

# FXBO (MySQL read-only)
FXDEALER_FXBO_HOST=
FXDEALER_FXBO_PORT=3306
FXDEALER_FXBO_DB=
FXDEALER_FXBO_USER=
FXDEALER_FXBO_PASSWORD=
