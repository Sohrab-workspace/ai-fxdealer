# AI FXDealer — Test environment
# No real secrets. Used with docker/docker-compose.test.yml.
# Committed to git — must never contain real credentials.

FXDEALER_DB_URL=postgresql://fxdealer:fxdealer_test@localhost:5433/fxdealer_test
FXDEALER_REDIS_URL=redis://localhost:6380/0
FXDEALER_JWT_SECRET=test-jwt-secret-not-for-production
FXDEALER_JWT_EXPIRY_SECONDS=3600
FXDEALER_AWS_REGION=eu-west-1
FXDEALER_SENTRY_DSN=
FXDEALER_LOG_LEVEL=DEBUG
FXDEALER_DEPLOYMENT_MODE=saas
